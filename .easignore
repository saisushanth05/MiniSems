# EAS Build — files to exclude from the uploaded tarball
# Keeps the tarball small so uploads don't time out (ECONNRESET)

# Node dependency directory (EAS will install it fresh on the server)
node_modules/

# Version control & lock directories
.git/
.bundle/

# Expo local cache
.expo/

# Scratch and CSV templates
scratch/
*.csv

# Android local build outputs
android/app/build/
android/build/
android/.gradle/
android/app/.cxx/

# iOS build artifacts
ios/build/
ios/Pods/
ios/DerivedData/

# Metro bundler cache
.metro-health-check*

# Local env files (keep secrets off EAS)
.env.local
.env.*.local

# Editor / OS noise
.DS_Store
Thumbs.db
*.log

# Test & coverage
coverage/
__tests__/__snapshots__/
